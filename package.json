{
  "name": "claude-code-proxy",
  "displayName": "Claude Code Proxy",
  "description": "管理 Claude Code 配置并切换；每条配置可选直连或通过本地代理（代理只重试 Claude Code 处理不了的 503+10310，其余透传交给 Claude Code）。",
  "version": "1.0.2",
  "publisher": "zaczh",
  "repository": {
    "type": "git",
    "url": "https://github.com/yananzhi/claude-code-proxy.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-code-proxy",
          "title": "Claude Code Proxy",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claude-code-proxy": [
        {
          "id": "claude-code-proxy.configs",
          "name": "LLM Configs"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "claude-code-proxy.newConfig",
          "when": "view == claude-code-proxy.configs",
          "group": "navigation"
        },
        {
          "command": "claude-code-proxy.refresh",
          "when": "view == claude-code-proxy.configs",
          "group": "navigation"
        },
        {
          "command": "claude-code-proxy.toggleProxyBackupOn",
          "when": "view == claude-code-proxy.configs && !claude-code-proxy.proxyToggleEnabled",
          "group": "navigation"
        },
        {
          "command": "claude-code-proxy.toggleProxyBackupOff",
          "when": "view == claude-code-proxy.configs && claude-code-proxy.proxyToggleEnabled",
          "group": "navigation"
        },
        {
          "command": "claude-code-proxy.exportConfigs",
          "when": "view == claude-code-proxy.configs"
        },
        {
          "command": "claude-code-proxy.importConfigs",
          "when": "view == claude-code-proxy.configs"
        }
      ],
      "view/item/context": [
        {
          "command": "claude-code-proxy.switchConfig",
          "when": "view == claude-code-proxy.configs && viewItem == config",
          "group": "inline@1"
        },
        {
          "command": "claude-code-proxy.editConfig",
          "when": "view == claude-code-proxy.configs && viewItem == config",
          "group": "inline@2"
        },
        {
          "command": "claude-code-proxy.deleteConfig",
          "when": "view == claude-code-proxy.configs && viewItem == config",
          "group": "inline@3"
        }
      ]
    },
    "commands": [
      {
        "command": "claude-code-proxy.newConfig",
        "title": "New LLM Config",
        "icon": "$(add)"
      },
      {
        "command": "claude-code-proxy.editConfig",
        "title": "Edit",
        "icon": "$(edit)"
      },
      {
        "command": "claude-code-proxy.switchConfig",
        "title": "Switch to This Config",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "claude-code-proxy.deleteConfig",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "claude-code-proxy.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "claude-code-proxy.openView",
        "title": "Open Claude Code Proxy"
      },
      {
        "command": "claude-code-proxy.openProxyUI",
        "title": "LLM 代理: 打开控制台（重试参数 + Trace）",
        "category": "Claude Code Proxy"
      },
      {
        "command": "claude-code-proxy.killProxy",
        "title": "LLM 代理: 重启代理（关闭监听，宿主心跳自动重起）",
        "category": "Claude Code Proxy"
      },
      {
        "command": "claude-code-proxy.toggleProxyBackup",
        "title": "LLM 代理: 切换本窗口 backup proxy 开关",
        "category": "Claude Code Proxy"
      },
      {
        "command": "claude-code-proxy.toggleProxyBackupOn",
        "title": "LLM 代理: 开启本窗口 backup proxy",
        "icon": "$(debug-start)",
        "enablement": "!claude-code-proxy.proxyToggleEnabled"
      },
      {
        "command": "claude-code-proxy.toggleProxyBackupOff",
        "title": "LLM 代理: 关闭本窗口 backup proxy",
        "icon": "$(debug-stop)",
        "enablement": "claude-code-proxy.proxyToggleEnabled"
      },
      {
        "command": "claude-code-proxy.exportConfigs",
        "title": "Export Configs",
        "icon": "$(export)"
      },
      {
        "command": "claude-code-proxy.importConfigs",
        "title": "Import Configs",
        "icon": "$(cloud-download)"
      }
    ],
    "configuration": {
      "title": "Claude Code Proxy",
      "properties": {
        "claude-code-proxy.configFilePath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Override the Claude Code settings.json path. Leave empty to auto-detect (`~/.claude/settings.json` on all platforms, including WSL)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.4.0"
  }
}
